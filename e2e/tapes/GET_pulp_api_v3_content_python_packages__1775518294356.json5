                {
                    pulp_href: '/pulp/api/v3/content/python/packages/019d17df-c93d-7adb-895d-03f2ee0dd973/',
                    prn: 'prn:python.pythonpackagecontent:019d17df-c93d-7adb-895d-03f2ee0dd973',
                    pulp_created: '2026-03-22T23:27:15.263320Z',
