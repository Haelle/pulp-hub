                {
                    pulp_href: '/pulp/api/v3/content/python/packages/019d17df-c9c8-74be-b66d-0485dc2a8dbc/',
                    prn: 'prn:python.pythonpackagecontent:019d17df-c9c8-74be-b66d-0485dc2a8dbc',
                    pulp_created: '2026-03-22T23:27:15.401520Z',
